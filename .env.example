# ============================================================
# 카드뉴스 자동화 공장 — 환경변수 템플릿
# ============================================================
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채워 넣으세요.
# .env 는 .gitignore 에 의해 깃에 커밋되지 않습니다.
# 절대 채팅에 키 값을 붙여넣지 마세요.
# ============================================================

# --- OpenAI API ---
# https://platform.openai.com/api-keys 에서 발급
# 용도 3가지:
#   1) DALL-E 3 / gpt-image-1 — 이미지 생성 (아트디렉터)
#   2) GPT-5 — 카피 A/B 비교 중 B 버전 생성 (Claude Opus 와 병렬)
# 필수 — 없으면 bot-runtime 기동 안 됨
OPENAI_API_KEY=

# --- Anthropic API ---
# https://console.anthropic.com/ 에서 발급
# Phase 2: Node.js 폴링 런타임에서 에이전트(editor/copy/art) LLM 호출용
ANTHROPIC_API_KEY=

# --- 텔레그램 봇 토큰 (3개) ---
# BotFather(@BotFather)에서 봇 생성 후 각 봇의 토큰 붙여넣기

# 편집장 — 총괄 + 배포
TELEGRAM_BOT_EDITOR=           # @HanwhaFinanceNewsBot

# 카피라이터 — 오디언스/시사점/카피
TELEGRAM_BOT_COPY=             # @hl_copywriter_bot

# 아트디렉터 — 디자인 + HTML + 이미지 생성
TELEGRAM_BOT_ART=              # @hl_artdirector_bot

# --- 텔레그램 그룹방 ID (다중 지원) ---
# 쉼표 구분으로 여러 그룹 운영 가능. 팀원 각자 그룹을 추가하세요.
# 허용된 그룹에서만 봇 동작. 그룹마다 독립 세션 (격리).
#
# 새 그룹 추가 절차:
#   1) BotFather 에서 생성한 봇 3개를 새 그룹에 초대 (편집장·카피·아트)
#   2) 각 봇의 /setprivacy 를 Disable 로 (그룹 내 모든 메시지 수신)
#   3) 그룹 ID 조회: @userinfobot 을 그룹에 초대해서 group id 확인
#   4) 아래 TELEGRAM_GROUP_IDS 에 쉼표로 추가
TELEGRAM_GROUP_IDS=-5041725581  # 기본 카드뉴스 작업 그룹
# 예) 여러 그룹: TELEGRAM_GROUP_IDS=-5041725581,-1001234567890,-1009876543210
#
# 레거시 호환: 단수 TELEGRAM_GROUP_ID 도 여전히 동작 (TELEGRAM_GROUP_IDS 가 없을 때만)
